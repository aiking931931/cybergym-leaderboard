{
  manifest_version: "0.1.0",
  program: {
    image: "cybergym-purple:latest",
    entrypoint: "uv run --no-sync python src/server.py --host 0.0.0.0 --port 9010",
    env: {
      PYTHONUNBUFFERED: "1",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9010 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
    },
    required: [],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
}
